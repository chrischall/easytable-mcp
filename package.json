{
  "name": "easytable-mcp",
  "version": "0.0.0",
  "mcpName": "io.github.chrischall/easytable-mcp",
  "description": "easyTable MCP server for Claude — developed and maintained by AI (Claude Code)",
  "author": "Claude Code (AI) <https://www.anthropic.com/claude>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrischall/easytable-mcp.git"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai",
    "easytable",
    "restaurant",
    "reservation",
    "booking"
  ],
  "type": "module",
  "bin": {
    "easytable-mcp": "dist/bundle.js"
  },
  "files": [
    "dist",
    ".claude-plugin",
    ".mcp.json",
    "server.json",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsc && npm run bundle",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --banner:js='import { createRequire as __createRequire } from \"module\"; const require = __createRequire(import.meta.url);' --outfile=dist/bundle.js",
    "dev": "node dist/bundle.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@chrischall/mcp-utils": "^0.12.0",
    "@fetchproxy/server": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "node-html-parser": "^9.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.7"
  }
}
